# Firebase Configuration
# Copy this file to .env and fill in your actual Firebase credentials
# Get these from Firebase Console > Project Settings > Your apps > Web app

REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# AI Service Configuration (OpenRouter API)
# Get your free API key from: https://openrouter.ai/keys
# This enables AI-powered job description analysis and skill matching in Resume Builder
REACT_APP_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Resume Generation Service (placement-backend)
# URL of the resume generation API server (default: http://localhost:5001/api)
# Leave empty to use client-side generation only
REACT_APP_RESUME_API_URL=http://localhost:5001/api